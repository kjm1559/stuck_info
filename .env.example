# Stock News Aggregator
# Required environment configuration

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_news

# Finnhub API Key
# Get your free API key at https://finnhub.io/api-key
FINNHUB_API_KEY=your_finnhub_api_key_here

# Redis for Celery
REDIS_HOST=localhost
REDIS_PORT=6379

# Application
APP_NAME=stock-news-api
APP_DEBUG=true
